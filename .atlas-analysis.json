  "keyFeatures": [
    "Smart auto-detection of lyrics format via AutoParser",
    "Syllable-level timing for karaoke-style highlighting",
    "Support for LRC, Enhanced LRC, TTML (Apple Music), Lyricify Syllable, and Kugou KRC formats",
    "Dual-language / translation line support",
    "Export parsed lyrics back to LRC, Enhanced LRC, or TTML",
    "Extensible via ILyricsParser interface for custom formats",
    "PhoneticProvider interface for romanization/phonetic annotations",
    "Kotlin Multiplatform: JVM, JS, Wasm, iOS, macOS",
    "LRC metadata extraction (title, artist, album, offset)",
    "Background vocal / accompaniment line support"
  ],
